generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum LeadStatus {
  new
  contacted
  qualified
  unqualified
  converted
  archived
}

enum PreferredContactMethod {
  email
  phone
  whatsapp
}

/// Marketing leads captured from the public landing page.
/// These are pre-tenant records — no school_id association yet.
model Lead {
  id                     String                 @id @default(cuid())
  fullName               String
  schoolName             String
  role                   String
  email                  String
  phone                  String?
  numberOfStudents       String?
  preferredContactMethod PreferredContactMethod @default(email)
  message                String?
  source                 String                 @default("marketing_page")
  status                 LeadStatus             @default(new)
  consentToContact       Boolean                @default(false)
  consentTimestamp       DateTime?
  consentVersion         String?
  utmSource              String?
  utmMedium              String?
  utmCampaign            String?
  utmTerm                String?
  utmContent             String?
  referrer               String?
  landingPage            String?
  ipAddress              String?
  userAgent              String?
  metadata               Json?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  @@unique([email])
  @@index([status])
  @@index([source])
  @@index([createdAt])
}

// ==========================================
// Phase 2A Core Entities
// ==========================================

enum SchoolStatus {
  lead
  approved
  invited
  onboarding
  active
  paused
  archived
}

model School {
  id                String       @id @default(cuid())
  name              String
  email             String?
  phone             String?
  estimatedStudents String?
  address           String?
  status            SchoolStatus @default(onboarding)
  selectedPlan      String       @default("freemium")
  planStatus        String       @default("active")
  planStartedAt     DateTime     @default(now())
  trialEndsAt       DateTime?
  planLimits        Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // Relations
  users                     User[]
  invitations               Invitation[]
  sessions                  AcademicSession[]
  terms                     AcademicTerm[]
  divisions                 Division[]
  classLevels               ClassLevel[]
  classArms                 ClassArm[]
  students                  Student[]
  parents                   Parent[]
  feeItems                  FeeItem[]
  classFeeTemplates         ClassFeeTemplate[]
  invoices                  Invoice[]
  payments                  Payment[]
  auditLogs                 AuditLog[]
  discountRules             DiscountRule[]
  bankName                  String?
  bankAccountNumber         String?
  bankAccountName           String?
  manualSubmissions         ManualPaymentSubmission[]
  notifications             NotificationOutbox[]
  studentActivityEnrolments StudentActivityEnrolment[]
  parentWardLinks           ParentWardLink[]
  lifecycleEvents           LifecycleEvent[]
  notificationHistories     NotificationHistory[]
  notificationPreferences   NotificationPreference[]
  pushSubscriptions         PushSubscription[]
  subscription              SchoolSubscription?
  subscriptionInvoices      SubscriptionInvoice[]
  billingTransactions       BillingTransaction[]
}

enum UserRole {
  SchoolOwner
  Principal
  Bursar
  Admin
}

model User {
  id                        String    @id @default(cuid())
  schoolId                  String
  school                    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  email                     String    @unique
  passwordHash              String
  fullName                  String
  role                      UserRole  @default(Bursar)
  emailVerified             Boolean   @default(false)
  emailVerifiedAt           DateTime?
  verificationCodeHash      String?
  verificationCodeExpiresAt DateTime?
  verificationAttempts      Int       @default(0)
  lastVerificationSentAt    DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  // Relations
  recordedPayments    Payment[]                    @relation("ActorRelation")
  reviewedSubmissions ManualPaymentSubmission[]    @relation("ReviewerRelation")

  @@index([schoolId])
}

model Invitation {
  id        String    @id @default(cuid())
  schoolId  String
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  email     String
  role      UserRole
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([schoolId])
  @@index([token])
}

model AcademicSession {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String // e.g. "2026/2027"
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  terms                     AcademicTerm[]
  studentActivityEnrolments StudentActivityEnrolment[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

enum TermStatus {
  active
  locked
}

model AcademicTerm {
  id        String          @id @default(cuid())
  schoolId  String
  school    School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sessionId String
  session   AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name      String // e.g. "First Term", "Second Term"
  status    TermStatus      @default(active)
  isActive  Boolean         @default(false)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  // Relations
  classFeeTemplates ClassFeeTemplate[]
  invoices          Invoice[]

  @@unique([sessionId, name])
  @@index([schoolId])
  @@index([sessionId])
}

model Division {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String // e.g. "Nursery", "Primary", "Secondary"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  classLevels ClassLevel[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model ClassLevel {
  id         String   @id @default(cuid())
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  divisionId String
  division   Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  name       String // e.g. "JSS1", "Primary 4"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  classArms         ClassArm[]
  students          Student[]
  classFeeTemplates ClassFeeTemplate[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([divisionId])
}

model ClassArm {
  id           String     @id @default(cuid())
  schoolId     String
  school       School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classLevelId String
  classLevel   ClassLevel @relation(fields: [classLevelId], references: [id], onDelete: Cascade)
  name         String // e.g. "JSS1A", "JSS1B"
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations
  students Student[]

  @@unique([classLevelId, name])
  @@index([schoolId])
  @@index([classLevelId])
}

enum StudentStatus {
  active
  inactive
  graduated
  transferred
  suspended
  withdrawn
  archived
}

model Student {
  id              String        @id @default(cuid())
  schoolId        String
  school          School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classLevelId    String
  classLevel      ClassLevel    @relation(fields: [classLevelId], references: [id])
  classArmId      String
  classArm        ClassArm      @relation(fields: [classArmId], references: [id])
  firstName       String
  lastName        String
  admissionNumber String
  gender          String?
  dateOfBirth     DateTime?
  status          StudentStatus @default(active)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  parents                   ParentWardLink[]
  invoices                  Invoice[]
  payments                  Payment[]
  manualSubmissions         ManualPaymentSubmission[]
  studentActivityEnrolments StudentActivityEnrolment[]

  @@unique([schoolId, admissionNumber])
  @@index([schoolId])
  @@index([classLevelId])
  @@index([classArmId])
}

model Parent {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  phone     String
  email     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  wards             ParentWardLink[]
  payments          Payment[]
  manualSubmissions ManualPaymentSubmission[]
  notifications     NotificationOutbox[]

  @@unique([schoolId, phone])
  @@index([schoolId])
}

enum RelationshipType {
  Mother
  Father
  Guardian
  Sponsor
  Other
}

model ParentWardLink {
  id                           String           @id @default(cuid())
  schoolId                     String
  school                       School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  parentId                     String
  parent                       Parent           @relation(fields: [parentId], references: [id], onDelete: Cascade)
  studentId                    String
  student                      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  relationshipType             RelationshipType @default(Guardian)
  isPrimaryContact             Boolean          @default(false)
  receivesInvoiceNotifications Boolean          @default(true)
  createdAt                    DateTime         @default(now())

  @@unique([parentId, studentId])
  @@index([schoolId])
  @@index([parentId])
  @@index([studentId])
}

enum FeeType {
  mandatory
  optional
}

enum BillingFrequency {
  per_term
  per_session
  one_off
}

model FeeItem {
  id               String           @id @default(cuid())
  schoolId         String
  school           School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name             String
  description      String?
  type             FeeType          @default(mandatory)
  billingFrequency BillingFrequency @default(per_term)
  amount           Decimal          @db.Decimal(12, 2)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  templateItems             ClassFeeTemplateItem[]
  studentActivityEnrolments StudentActivityEnrolment[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

enum TemplateStatus {
  draft
  published
}

model ClassFeeTemplate {
  id           String         @id @default(cuid())
  schoolId     String
  school       School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classLevelId String
  classLevel   ClassLevel     @relation(fields: [classLevelId], references: [id], onDelete: Cascade)
  termId       String
  term         AcademicTerm   @relation(fields: [termId], references: [id], onDelete: Cascade)
  status       TemplateStatus @default(draft)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Relations
  items    ClassFeeTemplateItem[]
  invoices Invoice[]

  // schoolId is included in the unique constraint to enforce per-school
  // uniqueness and prevent cross-tenant collisions.
  @@unique([schoolId, classLevelId, termId])
  @@index([schoolId])
  @@index([classLevelId])
  @@index([termId])
}

model ClassFeeTemplateItem {
  id             String           @id @default(cuid())
  templateId     String
  template       ClassFeeTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  feeItemId      String
  feeItem        FeeItem          @relation(fields: [feeItemId], references: [id], onDelete: Cascade)
  amountOverride Decimal?         @db.Decimal(12, 2)

  @@unique([templateId, feeItemId])
  @@index([templateId])
  @@index([feeItemId])
}

enum InvoiceStatus {
  draft
  issued
  partial
  paid
  overdue
}

model Invoice {
  id                 String            @id @default(cuid())
  schoolId           String
  school             School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId          String
  student            Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  termId             String
  term               AcademicTerm      @relation(fields: [termId], references: [id], onDelete: Cascade)
  templateId         String?
  template           ClassFeeTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  status             InvoiceStatus     @default(draft)
  dueDate            DateTime
  totalAmount        Decimal           @db.Decimal(12, 2) // Sum of original items
  discountAmount     Decimal           @default(0) @db.Decimal(12, 2)
  finalAmount        Decimal           @db.Decimal(12, 2) // totalAmount - discountAmount
  amountPaid         Decimal           @default(0) @db.Decimal(12, 2)
  balanceDue         Decimal           @db.Decimal(12, 2) // finalAmount - amountPaid
  overdueMarkedAt    DateTime?
  lastReminderSentAt DateTime?
  reminderCount      Int               @default(0)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  // Relations
  lineItems         InvoiceLineItem[]
  payments          Payment[]
  manualSubmissions ManualPaymentSubmission[]

  @@unique([studentId, termId])
  @@index([schoolId])
  @@index([studentId])
  @@index([termId])
  @@index([status])
}

enum LineItemType {
  fee_item
  carryover
  discount
  custom
}

model InvoiceLineItem {
  id        String       @id @default(cuid())
  invoiceId String
  invoice   Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  feeItemId String?
  name      String
  amount    Decimal      @db.Decimal(12, 2)
  lineType  LineItemType @default(fee_item)
  createdAt DateTime     @default(now())

  @@index([invoiceId])
}

enum PaymentMethod {
  cash
  bank_transfer
  pos
  cheque
  card
  online
}

enum PaymentStatus {
  recorded
  void
}

model Payment {
  id           String        @id @default(cuid())
  schoolId     String
  school       School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  invoiceId    String
  invoice      Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student       @relation(fields: [studentId], references: [id])
  parentId     String?
  parent       Parent?       @relation(fields: [parentId], references: [id])
  amount       Decimal       @db.Decimal(12, 2)
  method       PaymentMethod
  status       PaymentStatus @default(recorded)
  reference    String? // Transfer ref, Cheque number, etc.
  recordedById String?
  recordedBy   User?         @relation("ActorRelation", fields: [recordedById], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Relations
  receipts Receipt[]

  @@index([schoolId])
  @@index([invoiceId])
  @@index([studentId])
  @@index([parentId])
}

model Receipt {
  id            String   @id @default(cuid())
  schoolId      String
  paymentId     String
  payment       Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  receiptNumber String   @unique /// Format: PREFIX-YYYYMMDD-RAND (e.g. REC-20260708-XK4M) // Auto-generated string
  createdAt     DateTime @default(now())

  @@index([schoolId])
}

model AuditLog {
  id            String   @id @default(cuid())
  schoolId      String
  // IMPORTANT: onDelete: Restrict — audit logs must NEVER be cascade-deleted.
  // A school record cannot be deleted while audit logs exist.
  // Use a deliberate archival process that handles audit log retention separately.
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  actorId       String
  actorName     String
  action        String
  entityType    String
  entityId      String
  previousValue Json?
  newValue      Json?
  ipAddress     String?
  createdAt     DateTime @default(now())

  @@index([schoolId])
  @@index([createdAt])
}

enum ManualPaymentSubmissionStatus {
  Pending
  Approved
  Rejected
  ReuploadRequested
  Cancelled
}

model ManualPaymentSubmission {
  id              String                        @id @default(cuid())
  schoolId        String
  school          School                        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  invoiceId       String
  invoice         Invoice                       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  studentId       String
  student         Student                       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parentId        String
  parent          Parent                        @relation(fields: [parentId], references: [id], onDelete: Cascade)
  submittedById   String
  amount          Decimal                       @db.Decimal(12, 2)
  paymentMethod   PaymentMethod                 @default(bank_transfer)
  reference       String
  proofFileKey    String?
  proofFileName   String?
  proofFileType   String?
  proofFileSize   Int?
  status          ManualPaymentSubmissionStatus @default(Pending)
  rejectionReason String?
  reuploadReason  String?
  submittedAt     DateTime                      @default(now())
  reviewedAt      DateTime?
  reviewedById    String?
  reviewer        User?   @relation("ReviewerRelation", fields: [reviewedById], references: [id])

  @@index([schoolId])
  @@index([status])
}

enum NotificationChannel {
  email
  sms
}

enum NotificationStatus {
  pending
  processing
  sent
  failed
}

model NotificationOutbox {
  id          String              @id @default(cuid())
  schoolId    String
  school      School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  parentId    String
  parent      Parent              @relation(fields: [parentId], references: [id], onDelete: Cascade)
  channel     NotificationChannel
  status      NotificationStatus  @default(pending)
  recipient   String // email address or phone number
  subject     String? // For email
  content     String // Email HTML or SMS text
  reference   String? // e.g. invoiceId, paymentId for tracing
  errorLog    String?
  retryCount  Int                 @default(0)
  maxRetries  Int                 @default(3)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  processedAt DateTime?

  @@index([schoolId])
  @@index([status, retryCount])
  @@index([parentId])
}

// ==========================================
// Phase 2B Part 2: Discounts and Optional Fees
// ==========================================

enum DiscountRuleType {
  fixed
  percentage
}

enum DiscountScope {
  all_students
  specific_class
  specific_class_arm
}

enum DiscountCondition {
  sibling_count
  early_payment
  manual
}

model DiscountRule {
  id        String            @id @default(cuid())
  schoolId  String
  school    School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String
  type      DiscountRuleType
  value     Decimal           @db.Decimal(12, 2)
  condition DiscountCondition
  scope     DiscountScope     @default(all_students)
  isActive  Boolean           @default(true)

  // Conditionally used based on condition/scope
  conditionValue String? // e.g., "2" for sibling count threshold, or ISO date for early payment
  feeItemId      String? // If null, applies to invoice total
  classLevelId   String?
  classArmId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
}

// ==========================================
// Phase 2B Part 2: Student Activity Enrolment
// ==========================================

model StudentActivityEnrolment {
  id        String          @id @default(cuid())
  schoolId  String
  school    School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId String
  student   Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeItemId String
  feeItem   FeeItem         @relation(fields: [feeItemId], references: [id], onDelete: Cascade)
  sessionId String
  session   AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())

  @@unique([studentId, feeItemId, sessionId])
  @@index([schoolId])
  @@index([studentId])
  @@index([feeItemId])
}

// =========================================================
// Phase 2B Enhancement: Lifecycle Automation & Engagement
// =========================================================

/// Records important user journey milestones for lifecycle automation
model LifecycleEvent {
  id         String   @id @default(cuid())
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId     String   // admin user who performed the action
  milestone  String   // "account_created", "setup_completed", "first_invoice", etc.
  occurredAt DateTime @default(now())
  metadata   Json?

  @@index([schoolId, userId])
  @@index([milestone, occurredAt])
}

/// Tracks sent lifecycle notifications for dedup and analytics
model NotificationHistory {
  id         String    @id @default(cuid())
  schoolId   String
  school     School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId     String?
  trigger    String    // "signup_7d", "missing_invoices", etc.
  channel    String    // "email", "sms"
  template   String    // template identifier
  recipient  String
  subject    String?
  status     String    // "queued", "sent", "failed", "skipped"
  providerId String?   // Resend/Termii message ID
  sentAt     DateTime?
  failedAt   DateTime?
  errorLog   String?
  createdAt  DateTime  @default(now())

  @@index([schoolId])
  @@index([trigger, status])
  @@index([schoolId, userId, trigger])
}

/// Push notification subscriptions for PWA
model PushSubscription {
  id         String   @id @default(cuid())
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  parentId   String
  endpoint   String   @unique
  p256dh     String
  auth       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([schoolId])
  @@index([parentId])
}

/// User notification preferences (opt-in/out per channel/category)
model NotificationPreference {
  id         String   @id @default(cuid())
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId     String?
  parentId   String?
  channel    String   // "email", "sms"
  category   String   // "marketing", "product_updates", "reminders"
  subscribed Boolean  @default(true)
  updatedAt  DateTime @updatedAt

  @@unique([schoolId, userId, parentId, channel, category])
  @@index([schoolId])
}

// ==========================================
// Phase 2C — Subscription & Billing
// ==========================================

/// Available subscription plans (seeded, not user-managed)
model PricingPlan {
  id            String   @id // "starter_free", "pro_term", "group_custom"
  name          String   // "Starter", "Pro", "Group"
  tier          Int      @default(0) // 0=free, 1=paid, 2=enterprise
  price         Decimal  @default(0) @db.Decimal(12, 2)
  currency      String   @default("NGN")
  billingPeriod String?  // "term", null for free/one-off
  features      Json     // feature flag map
  limits        Json     // { maxStudents, maxStaff, maxWorkspaces, ... }
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions SchoolSubscription[]

  @@map("pricing_plans")
}

/// Per-school subscription record
model SchoolSubscription {
  id                 String   @id @default(cuid())
  schoolId           String   @unique
  school             School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  planId             String
  plan               PricingPlan @relation(fields: [planId], references: [id])
  status             String   @default("trialing") // trialing | active | past_due | suspended | cancelled | expired
  autoRenew          Boolean  @default(true)
  cancelAtPeriodEnd  Boolean  @default(false)
  trialStartedAt     DateTime @default(now())
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  flwCustomerId      String?  // Flutterwave customer ID for tokenized charges
  flwCardToken       Json?    // Saved card token for recurring billing
  metadata           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  invoices       SubscriptionInvoice[]
  transactions   BillingTransaction[]

  @@index([status])
  @@index([planId])
  @@map("school_subscriptions")
}

/// Subscription invoices (WardBalance charges to schools)
model SubscriptionInvoice {
  id                String   @id @default(cuid())
  subscriptionId    String
  subscription      SchoolSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  schoolId          String
  school            School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  invoiceNumber     String   @unique // e.g. "INV-WB-2026-00001"
  planId            String
  amount            Decimal  @default(0) @db.Decimal(12, 2)
  currency          String   @default("NGN")
  status            String   @default("pending") // pending | paid | failed | refunded
  periodStart       DateTime
  periodEnd         DateTime
  paidAt            DateTime?
  flwTransactionId  String?
  receiptUrl        String?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  transactions BillingTransaction[] @relation("InvoiceTransactions")

  @@index([subscriptionId])
  @@index([schoolId])
  @@index([status])
  @@index([invoiceNumber])
  @@map("subscription_invoices")
}

/// Individual billing transactions
model BillingTransaction {
  id               String   @id @default(cuid())
  invoiceId        String
  invoice          SubscriptionInvoice @relation("InvoiceTransactions", fields: [invoiceId], references: [id], onDelete: Cascade)
  subscriptionId   String
  subscription     SchoolSubscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  schoolId         String
  school           School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  amount           Decimal  @default(0) @db.Decimal(12, 2)
  currency         String   @default("NGN")
  paymentMethod    String?  // "card", "bank_transfer", "ussd"
  flwTransactionId String?  @unique
  status           String   @default("pending") // pending | success | failed
  failureReason    String?
  metadata         Json?
  createdAt        DateTime @default(now())

  @@index([invoiceId])
  @@index([flwTransactionId])
  @@index([schoolId])
  @@map("billing_transactions")
}
